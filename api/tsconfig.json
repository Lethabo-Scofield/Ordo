{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "allowJs": true
  },
  "include": ["./**/*.ts"]
}
